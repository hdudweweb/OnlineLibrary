<Page x:Class="OnlineLibrary1.Pages.ReadingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OnlineLibrary1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ReadingPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель инструментов -->
        <Border Grid.Row="0" Background="#4a6fa5" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="◀ Назад" 
                        Click="BackButton_Click"
                        Background="Transparent"
                        BorderThickness="0"/>

                <TextBlock x:Name="BookTitleText" 
                          Foreground="White"
                          FontSize="18"
                          VerticalAlignment="Center"
                          Margin="20,0"/>

                <Button Content="Выйти" 
                        Click="ExitButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- Текст книги -->
        <ScrollViewer Grid.Row="1">
            <TextBlock x:Name="BookContentText" 
                      Margin="40"
                      FontSize="16"
                      LineHeight="28"
                      TextWrapping="Wrap"
                      TextAlignment="Justify"/>
        </ScrollViewer>

        <!-- Панель навигации -->
        <Border Grid.Row="2" Background="#f5f5f5" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="◀◀" 
                        Click="FirstPage_Click"
                        Margin="0,0,10,0"/>
                <Button Content="◀" 
                        Click="PrevPage_Click"
                        Margin="0,0,10,0"/>

                <TextBox x:Name="PageNumberText" 
                        Width="50" 
                        TextAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Text="1"/>

                <TextBlock Text="/ 100" 
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>

                <Button Content="▶" 
                        Click="NextPage_Click"
                        Margin="0,0,10,0"/>
                <Button Content="▶▶" 
                        Click="LastPage_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
