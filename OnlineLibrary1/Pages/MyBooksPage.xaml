<Page x:Class="OnlineLibrary1.Pages.MyBooksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OnlineLibrary1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MyBooksPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        

        <!-- Список книг -->
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="White"  Padding="16"
                BorderBrush="#E6EAF0" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Мои книги" FontSize="24" FontWeight="Bold" Foreground="#1F2D3D"/>
                        <TextBlock x:Name="CountText"
                               Text="0 книг"
                               Margin="0,4,0,0"
                               Foreground="#637081"/>
                        
                    </StackPanel>

                    <!-- Search -->
                    <Border Grid.Column="1" Background="#F3F6FA"  Padding="10"
                        BorderBrush="#E6EAF0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            

                            <TextBox x:Name="SearchTextBox"
                                 Height="34"
                                 Padding="10,6"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 TextChanged="SearchTextBox_TextChanged"
                                 FontSize="13"
                                 Foreground="#1F2D3D"
                                 ToolTip="Поиск по названию/автору"/>

                            <Button
                                Content="Очистить"
                                Padding="10,6"
                                Click="ClearSearch_Click"
                                Background="#4A6FA5"
                                Foreground="White"
                                Cursor="Hand" Grid.ColumnSpan="2" Margin="221,0,0,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" >
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Actions -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,12">
                <Button Content="Обновить"
                    Click="Refresh_Click"
                    Padding="12,6"
                    Background="#2E8B57"
                    Foreground="White"
                    Cursor="Hand" Width="90">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" >
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Очистить мои книги"
                    Margin="10,0,0,0"
                    Click="ClearFavorites_Click"
                    Padding="12,6"
                    Background="#E74C3C"
                    Foreground="White"
                    Cursor="Hand" Width="140">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" >
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <ComboBox x:Name="StatusFilterComboBox"
          Width="180"
          Height="32"
          Margin="20,0,0,0"
          VerticalContentAlignment="Center"
          SelectionChanged="StatusFilterChanged">
                    <ComboBoxItem Content="Все"/>
                    <ComboBoxItem Content="Читаю"/>
                    <ComboBoxItem Content="В планах"/>
                    <ComboBoxItem Content="Прочитано"/>
                </ComboBox>
            </StackPanel>

            <!-- Content -->
            <Grid Grid.Row="2">
                <!-- No results -->
                <Border  x:Name="NoResultsPanel"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#E6EAF0"
                    BorderThickness="1"
                    Padding="20"
                    Visibility="Collapsed">
                    <StackPanel  HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📚" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="Пока нет книг"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,10,0,0"
                               HorizontalAlignment="Center"/>
                        <TextBlock Text="Добавь книгу в избранное на странице книги — и она появится здесь."
                               Foreground="#637081"
                               TextAlignment="Center"
                               Width="420"
                               Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="BooksList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                    CornerRadius="12"
                                    BorderBrush="#E6EAF0"
                                    BorderThickness="1"
                                    Margin="0,0,0,12"
                                    Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Cover -->
                                        <Border Width="80" Height="110" CornerRadius="10" ClipToBounds="True" Background="#F3F6FA">
                                            <Image Source="{Binding CoverImage}"
                                               Stretch="UniformToFill"/>
                                        </Border>

                                        <!-- Info -->
                                        <StackPanel Grid.Column="1" Margin="12,0,12,0">
                                            <TextBlock Text="{Binding Title}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="#1F2D3D"
                                                   TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Text="{Binding Author}"
                                                   Margin="0,4,0,0"
                                                   Foreground="#637081"
                                                   FontStyle="Italic"
                                                   TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Text="{Binding Meta}"
                                                   Margin="0,8,0,0"
                                                   Foreground="#637081"/>

                                            <TextBlock Text="{Binding DescriptionShort}"
                                                   Margin="0,8,0,0"
                                                   Foreground="#1F2D3D"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="40"/>
                                        </StackPanel>

                                        <!-- Buttons -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <Button Content="Открыть"
                                                Padding="12,6"
                                                Background="#4A6FA5"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Click="Open_Click"
                                                Tag="{Binding BookId}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <Button Content="Удалить"
                                                Margin="0,8,0,0"
                                                Padding="12,6"
                                                Background="#F3F6FA"
                                                Foreground="#E74C3C"
                                                BorderBrush="#E6EAF0"
                                                BorderThickness="1"
                                                Cursor="Hand"
                                                Click="Remove_Click"
                                                Tag="{Binding BookId}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
