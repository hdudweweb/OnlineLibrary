<Page x:Class="OnlineLibrary1.Pages.Profiel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OnlineLibrary1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Profiel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="White"
                    CornerRadius="12"
                    BorderBrush="#E6EAF0"
                    BorderThickness="1"
                    Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Профиль"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#1F2D3D"/>
                        <TextBlock x:Name="SubtitleText"
                                   Text="Данные вашего аккаунта"
                                   Margin="0,4,0,0"
                                   Foreground="#637081"/>
                    </StackPanel>

                    <Button
                            Content="Обновить"
                            Padding="12,6"
                            Background="#2E8B57"
                            Foreground="White"
                            Cursor="Hand"
                            Click="Refresh_Click" Margin="659,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" >
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Warning if not auth -->
            <Border x:Name="NotAuthPanel"
                    Grid.Row="1"
                    Margin="0,12,0,0"
                    Background="#FFF3CD"
                    BorderBrush="#FFECB5"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12"
                    Visibility="Collapsed">
                <TextBlock Text="Вы не авторизованы. Войдите, чтобы видеть и менять данные профиля."
                           Foreground="#664D03"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Profile card -->
            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#E6EAF0"
                    BorderThickness="1"
                    Padding="16"
                    Margin="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar -->
                        <StackPanel>
                            <Border Width="140"
                                    Height="140"
                                    CornerRadius="70"
                                    Background="#F3F6FA"
                                    BorderBrush="#E6EAF0"
                                    BorderThickness="1"
                                    HorizontalAlignment="Left"
                                    ClipToBounds="True">
                                <Grid>
                                    <Image x:Name="AvatarImage" Stretch="UniformToFill"/>
                                    <TextBlock x:Name="AvatarPlaceholder"
                                               Text="👤"
                                               FontSize="46"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#637081"/>
                                </Grid>
                            </Border>

                            <Button Content="Загрузить фото"
                                    Margin="0,12,0,0"
                                    Padding="12,6"
                                    Background="#4A6FA5"
                                    Foreground="White"
                                    Cursor="Hand"
                                    Click="UploadAvatar_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" >
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- Info -->
                        <Grid Grid.Column="1" Margin="16,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Имя пользователя" Foreground="#637081"/>
                            <TextBlock x:Name="UsernameText" Grid.Column="1" Text="—" FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="1" Text="Email" Foreground="#637081"/>
                            <TextBlock x:Name="EmailText" Grid.Row="1" Grid.Column="1" Text="—" FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="2" Text="Роль" Foreground="#637081"/>
                            <TextBlock x:Name="RoleText" Grid.Row="2" Grid.Column="1" Text="—" FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="3" Text="Дата регистрации" Foreground="#637081"/>
                            <TextBlock x:Name="CreatedText" Grid.Row="3" Grid.Column="1" Text="—" FontWeight="SemiBold"/>

                            <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,14,0,0">
                                <Button Content="Редактировать"
                                        Padding="12,6"
                                        Background="#4A6FA5"
                                        Foreground="White"
                                        Cursor="Hand"
                                        Click="EditProfile_Click" Width="105">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" >
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Content="Сменить пароль"
                                        Margin="10,0,0,0"
                                        Padding="12,6"
                                        Background="#F3F6FA"
                                        Foreground="#4A6FA5"
                                        BorderBrush="#E6EAF0"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Click="ChangePassword_Click" Width="115">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- Stats -->
                    <Border Grid.Row="1"
                            Margin="0,18,0,0"
                            Background="#F8FAFC"
                            BorderBrush="#E6EAF0"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <UniformGrid Columns="4">
                            <StackPanel>
                                <TextBlock Text="Всего" Foreground="#637081"/>
                                <TextBlock x:Name="TotalBooksText" Text="—" FontSize="20" FontWeight="Bold" Foreground="#1F2D3D"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Читаю" Foreground="#637081"/>
                                <TextBlock x:Name="ReadingBooksText" Text="—" FontSize="20" FontWeight="Bold" Foreground="#1F2D3D"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="В планах" Foreground="#637081"/>
                                <TextBlock x:Name="PlannedBooksText" Text="—" FontSize="20" FontWeight="Bold" Foreground="#1F2D3D"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Прочитано" Foreground="#637081"/>
                                <TextBlock x:Name="FinishedBooksText" Text="—" FontSize="20" FontWeight="Bold" Foreground="#1F2D3D"/>
                            </StackPanel>
                        </UniformGrid>
                    </Border>

                    <TextBlock Grid.Row="2"
                               x:Name="StatsHintText"
                               Margin="0,10,0,0"
                               Foreground="#637081"
                               Text="Статистика берётся из «Мои книги»."
                               Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
