<Page x:Class="OnlineLibrary1.Pages.BoolDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OnlineLibrary1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BoolDetailsPage">

    <ScrollViewer>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Обложка книги -->
            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="6"
                    BorderBrush="#ddd" BorderThickness="1"
                    CornerRadius="5" 
                    Height="350"
                    VerticalAlignment="Top"
                    Background="#f0f8ff">
                <Grid>
                    <!-- Обложка -->
                    <Border x:Name="BookCoverBorder" 
                            CornerRadius="5">
                        <TextBlock x:Name="BookIcon" 
                                  Text="📖" 
                                  FontSize="72"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"
                                  Opacity="0.8"/>
                    </Border>

                    <!-- Рейтинг -->
                    <Border Background="#4a6fa5"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="10"
                            Padding="5,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="★" 
                                      Foreground="Gold"
                                      FontWeight="Bold"
                                      VerticalAlignment="Center"/>
                            <TextBlock x:Name="RatingText" 
                                      Text="4.8" 
                                      Foreground="White"
                                      FontWeight="Bold"
                                      Margin="2,0,0,0"
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Возрастной рейтинг -->
                    <Border x:Name="AgeRatingBorder"
                            Background="#e74c3c"
                            CornerRadius="3"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="10"
                            Padding="5,2">
                        <TextBlock x:Name="AgeRatingText" 
                                  Text="16+" 
                                  Foreground="White"
                                  FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Название -->
            <TextBlock x:Name="TitleText" 
                      Grid.Row="0" Grid.Column="2"
                      FontSize="28" 
                      FontWeight="Bold"
                      TextWrapping="Wrap"
                      Margin="0,0,0,10"/>

            <!-- Автор -->
            <TextBlock x:Name="AuthorText" 
                      Grid.Row="1" Grid.Column="2"
                      FontSize="20"
                      Margin="0,0,0,15"
                      Foreground="#4a6fa5"/>

            <!-- Основная информация -->
            <Border Grid.Row="2" Grid.Column="2"
                    BorderBrush="#e0e0e0" 
                    BorderThickness="0,1,0,1"
                    Padding="0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Год -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Год издания" 
                                  FontSize="12"
                                  Foreground="Gray"/>
                        <TextBlock x:Name="YearText" 
                                  FontSize="16"
                                  FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Страницы -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Страниц" 
                                  FontSize="12"
                                  Foreground="Gray"/>
                        <TextBlock x:Name="PagesText" 
                                  FontSize="16"
                                  FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Жанр -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Жанр" 
                                  FontSize="12"
                                  Foreground="Gray"/>
                        <TextBlock x:Name="GenreText" 
                                  FontSize="16"
                                  FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ISBN и издательство -->
            <StackPanel Grid.Row="3" Grid.Column="2" 
                       Margin="0,15,0,15">
                <TextBlock x:Name="IsbnText" 
                          FontSize="14"
                          Margin="0,0,0,5"/>
                <TextBlock x:Name="PublisherText" 
                          FontSize="14"/>
            </StackPanel>

            <!-- Кнопки действий -->
            <Border Grid.Row="4" Grid.Column="2"
                    BorderBrush="#e0e0e0" 
                    BorderThickness="0,1,0,1"
                    Padding="0,15">
                <StackPanel>
                    <!-- Основные кнопки -->
                    <StackPanel Orientation="Horizontal" 
                               Margin="0,0,0,10">
                        <Button x:Name="ReadBookButton"
                                Content="Читать книгу"
                                Click="ReadBook_Click"
                                Width="200"
                                Height="40"
                                FontSize="16"
                                Background="#27ae60"
                                Margin="0,0,10,0">
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="Button.Click">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                           To="#219653" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>
                        </Button>

                        <!-- Кнопка добавления в мои книги -->
                        <Button x:Name="AddToMyBooksButton"
                                Content="Добавить в мои книги"
                                Click="AddToMyBooks_Click"
                                Width="200"
                                Height="40"
                                FontSize="16"
                                Background="#4a6fa5"
                                Margin="10,0,0,0">
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="Button.Click">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                           To="#3a5a8a" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>
                        </Button>
                    </StackPanel>

                    <!-- Панель выбора статуса (скрыта по умолчанию) -->
                    <Border x:Name="StatusSelectionPanel"
                           Visibility="Collapsed"
                           BorderBrush="#ddd"
                           BorderThickness="1"
                           CornerRadius="5"
                           Padding="15"
                           Margin="0,10,0,0"
                           Background="#f9f9f9">
                        <StackPanel>
                            <TextBlock Text="Выберите статус чтения:" 
                                      FontWeight="Bold"
                                      Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="ReadingNowRadio"
                                            Content="Читаю сейчас"
                                            GroupName="ReadingStatus"
                                            Margin="0,0,15,0"
                                            IsChecked="True"/>
                                <RadioButton x:Name="PlannedRadio"
                                            Content="В планах"
                                            GroupName="ReadingStatus"
                                            Margin="0,0,15,0"/>
                                <RadioButton x:Name="FinishedRadio"
                                            Content="Прочитано"
                                            GroupName="ReadingStatus"
                                            Margin="0,0,15,0"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" 
                                       HorizontalAlignment="Right"
                                       Margin="0,10,0,0">
                                <Button Content="Отмена"
                                        Click="CancelStatusSelection_Click"
                                        Background="Transparent"
                                        Foreground="#666"
                                        BorderThickness="0"
                                        Margin="0,0,10,0"/>
                                <Button Content="Добавить"
                                        Click="ConfirmAddToMyBooks_Click"
                                        Width="100"
                                        Background="#27ae60"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Статус книги в моей библиотеке -->
                    <Border x:Name="BookStatusPanel"
                           Visibility="Collapsed"
                           BorderBrush="#27ae60"
                           BorderThickness="1"
                           CornerRadius="5"
                           Padding="10"
                           Margin="0,10,0,0"
                           Background="#e8f9ef">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✓" 
                                      Foreground="#27ae60"
                                      FontWeight="Bold"
                                      FontSize="16"
                                      Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock x:Name="BookStatusText" 
                                          FontWeight="Bold"
                                          Foreground="#27ae60"/>
                                <TextBlock x:Name="BookProgressText" 
                                          FontSize="12"
                                          Foreground="#666"/>
                            </StackPanel>
                            <Button Content="Изменить"
                                    Click="ChangeStatus_Click"
                                    Background="Transparent"
                                    BorderBrush="#27ae60"
                                    BorderThickness="1"
                                    Margin="20,0,0,0"
                                    Padding="10,5"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Описание -->
            <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3"
                    BorderBrush="#ddd" 
                    BorderThickness="1"
                    CornerRadius="5" 
                    Padding="20"
                    Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="Описание" 
                              FontSize="18" 
                              FontWeight="Bold"
                              Margin="0,0,0,15"/>

                    <TextBlock x:Name="DescriptionText" 
                              TextWrapping="Wrap"
                              TextAlignment="Justify"
                              FontSize="14"
                              LineHeight="22"/>
                </StackPanel>
            </Border>

            <!-- Дополнительная информация -->
            <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                    BorderBrush="#ddd" 
                    BorderThickness="1"
                    CornerRadius="5" 
                    Padding="20"
                    Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="Дополнительная информация" 
                              FontSize="18" 
                              FontWeight="Bold"
                              Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Язык:" 
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,5"/>
                            <TextBlock x:Name="LanguageText" 
                                      Margin="0,0,0,15"/>

                            <TextBlock Text="Серия:" 
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,5"/>
                            <TextBlock x:Name="SeriesText" 
                                      Margin="0,0,0,15"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Дата добавления:" 
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,5"/>
                            <TextBlock x:Name="AddedDateText" 
                                      Margin="0,0,0,15"/>

                            <TextBlock Text="Популярность:" 
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,5"/>
                            <TextBlock x:Name="PopularityText" 
                                      Margin="0,0,0,15"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
