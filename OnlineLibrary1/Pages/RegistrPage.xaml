<Page x:Class="OnlineLibrary1.Pages.RegistrPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OnlineLibrary1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegistrPage">

    <Grid>
        <Border Background="#f8f9fa"
                Padding="30"
                CornerRadius="10"
                Width="400"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="500">
                <StackPanel>
                    <TextBlock Text="Регистрация"
                              FontSize="24"
                              FontWeight="Bold"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,20"/>

                    <TextBlock Text="Имя" Margin="0,0,0,5"/>
                    <TextBox x:Name="FirstNameBox" Margin="0,0,0,10"/>


                    <TextBlock Text="Email" Margin="0,0,0,5"/>
                    <TextBox x:Name="EmailBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Пароль" Margin="0,0,0,5"/>
                    <TextBox x:Name="PasswordBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Повторите пароль" Margin="0,0,0,5"/>
                    <TextBox x:Name="ConfirmPasswordBox" Margin="0,0,0,20"/>

                    <CheckBox x:Name="AgreementCheckBox" 
                             Content="Я согласен с условиями использования"
                             Margin="0,0,0,20"/>

                    <Button Content="Зарегистрироваться" 
                           Padding="15,10"
                           Click="Register_Click"
                           Margin="0,0,0,10"/>

                    <Button Content="Уже есть аккаунт? Войти" 
                           Padding="10,5"
                           Background="Transparent"
                           Foreground="#4a6fa5"
                           BorderThickness="0"
                           Click="Login_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
