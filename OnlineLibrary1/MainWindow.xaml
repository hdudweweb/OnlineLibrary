<Window x:Class="OnlineLibrary1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OnlineLibrary1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#4a6fa5" Padding="20">
            <TextBlock Text="Online Library" 
                      Foreground="White" 
                      FontSize="24"
                      FontWeight="Bold"
                      HorizontalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" 
                   Background="#f8f9fa" 
                   BorderBrush="#dee2e6" 
                   BorderThickness="0,0,1,0">
                <StackPanel Margin="10">
                    <Button x:Name="btnLogin" 
                           Content="Вход" 
                           Click="NavigateToLogin"
                           Margin="0,0,0,5"/>
                    <Button x:Name="btnRegister" 
                           Content="Регистрация" 
                           Click="NavigateToRegister"
                           Margin="0,0,0,5"/>
                    <Button x:Name="btnCatalog" 
                           Content="Каталог" 
                           Click="NavigateToCatalog"
                           Margin="0,0,0,5"/>
                    <Button x:Name="btnMyBooks" 
                           Content="Мои книги" 
                           Click="NavigateToMyBooks"
                           Margin="0,0,0,5"/>
                    <Button x:Name="btnAddBook" 
                           Content="Добавить книгу" 
                           Click="NavigateToAddBook"
                           Margin="0,0,0,5"/>
                    <Button x:Name="btnProfile" 
                           Content="Профиль" 
                           Click="NavigateToProfile"
                           Margin="0,0,0,5"/>

                    <Separator Margin="0,20,0,10"/>

                    <Button x:Name="btnLogout" 
                           Content="Выйти из аккаунта" 
                           Click="Logout_Click"
                           Background="#dc3545"
                           Visibility="Collapsed">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="#dc3545"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#c82333"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            
            <Frame x:Name="MainFrame" 
                  Grid.Column="1" 
                  NavigationUIVisibility="Hidden"
                  />
        </Grid>
        <Border Grid.Row="2" 
               Background="#f8f9fa" 
               BorderBrush="#dee2e6" 
               BorderThickness="0,1,0,0"
               Padding="10">
            <TextBlock Text="© 2026 Online Library" 
                      HorizontalAlignment="Center"
                      Foreground="#6c757d"/>
        </Border>
    </Grid>
</Window>
